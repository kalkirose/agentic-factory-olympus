{
  "schemaVersion": 1,

  "nextUnitQuery": {
    "kind": "sprint-file",
    "path": "docs/sprint-plan.md",
    "rule": "the first story whose status is ready-for-dev, in file order"
  },
  "readinessChecklist": [
    "spec file exists and lists acceptance criteria with IDs",
    "all stories this unit depends on are done",
    "referenced design docs exist at their stated paths"
  ],

  "commands": {
    "fullSuite": [
      { "name": "unit", "command": "npm test" },
      { "name": "integration", "command": "npm run test:integration" }
    ],
    "typecheck": "npm run typecheck",
    "targetedHint": "npm test -- <path>  (single file while iterating)"
  },

  "budget": {
    "maxTranscriptBytes": 8000000
  },

  "infraFlakeSignatures": [
    "EPERM: operation not permitted, rename.*(Temp|tmp)"
  ],

  "uiPathPatterns": ["^apps/web/src/(routes|components)/"],

  "testRalph": {
    "passes": 3,
    "adversaryCount": 5,
    "refinementRounds": 2,
    "killRateCommand": "npm test -- {tests}"
  },

  "hooks": {
    "formatOnEditCommand": "npx prettier --write {file}"
  },

  "conventions": {
    "branchTemplate": "story/{unit}",
    "prTargetBranch": "main",
    "prTitlePrefix": "[{unit}] ",
    "shipChecklist": [
      "copy the finalized story/spec file to docs/specs/<unit>.md and commit it on the branch (per-story spec-in-repo rule)"
    ]
  },

  "docPaths": {
    "conventions": "AGENTS.md",
    "adrs": "docs/adr/",
    "architecture": "docs/architecture.md",
    "glossary": null
  }
}
